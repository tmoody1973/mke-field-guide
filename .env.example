# Neon Postgres pooled connection string
DATABASE_URL=
# Ticketmaster Discovery API key (developer.ticketmaster.com) — free tier
TICKETMASTER_API_KEY=
# Eventbrite private token (eventbrite.com/platform) — for organizer-events sync
EVENTBRITE_PRIVATE_TOKEN=
# Firecrawl API key (firecrawl.dev) — only needed for JS-rendered sources
FIRECRAWL_API_KEY=
# Vercel AI Gateway — powers ingest-time embeddings + enrichment tagging AND the
# query-embedding half of hybrid search. Absent = search runs FTS-only, publishing unaffected.
AI_GATEWAY_API_KEY=
# Trigger.dev: `npx trigger.dev@latest login` handles CLI auth; tasks running in the
# Trigger.dev cloud read DATABASE_URL (and the API keys above) from the project's
# environment variables — sync them in the Trigger.dev dashboard before deploying.
# rm-playlist-v2 public Convex deployment — powers /api/now-playing (mini-player
# now-playing metadata). Absent = route always returns { none: true }.
RM_PLAYLIST_CONVEX_URL=
# Canonical site URL for metadataBase + absolute link generation. Absent = falls
# back to http://localhost:3000; set only once a production deploy exists.
NEXT_PUBLIC_SITE_URL=
# --- Phase 5: admin auth (Clerk) ---
# Absent: /admin is unusable (local dev falls back to Clerk keyless mode); public site unaffected.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
# Staff access: comma-separated emails, case-insensitive. admin = all tools;
# picks = staff-picks manager only. An email on both lists is admin.
ADMIN_ALLOWLIST_EMAILS=
PICKS_ALLOWLIST_EMAILS=
# Both lists also accept @domain entries (e.g. @radiomilwaukee.org) granting the
# tier to every Clerk-verified email at exactly that domain (no subdomains).
# Set to 1 to disable the newsletter per-IP throttle (e2e only — NEVER set in Vercel).
NEWSLETTER_THROTTLE_DISABLED=
# Trigger.dev project ref for admin dashboard run-detail links (proj_...).
TRIGGER_PROJECT_REF=
